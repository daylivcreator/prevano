# ─── Base ────────────────────────────────────────────────────
# URL publique du site (sans slash final)
SITE_URL=https://prevano.fr

# ─── Base de données (Neon / Supabase / Vercel Postgres) ─────
POSTGRES_URL=postgresql://user:password@host:5432/prevano?sslmode=require

# ─── Auth ────────────────────────────────────────────────────
# Générer avec : node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=

# ─── Anthropic ───────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Stripe ──────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_STARTER_PRICE_ID=price_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_PREMIUM_PRICE_ID=price_...

# ─── Email (Resend — https://resend.com) ─────────────────────
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@prevano.fr
EMAIL_SENDER_NAME=Prevano
EMAIL_SENDER_EMAIL=noreply@prevano.fr
